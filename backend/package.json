{
  "name": "marketplace-backend",
  "version": "1.0.0",
  "description": "Marketplace backend API — Node.js + TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register --project tsconfig.json src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node -r tsconfig-paths/register dist/index.js",
    "test": "jest --runInBand --forceExit",
    "seed": "ts-node -r tsconfig-paths/register --project tsconfig.json src/seeds/run-seeds.ts",
    "seed:vendor": "ts-node -r tsconfig-paths/register --project tsconfig.json src/seeds/seed-dashboard-vendor.ts",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.5.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.5",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pino": "^9.5.0",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.10",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/qs": "^6.15.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
